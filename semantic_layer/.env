# ── GraphRAG Semantic Layer — Environment Variables ─────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Neo4j ───────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=viranchi

# ── API Keys (only needed for cloud providers you actually use) ─
# Leave blank if using Ollama (local models) — no keys needed!
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Ollama (local models — zero cost, fully private) ──────────
# Install: https://ollama.com
# Then: ollama pull llama3.2 && ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── Embedding Configuration ────────────────────────────────────
# Use "ollama" for local embeddings, "openai" for cloud
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── LLM Defaults (overridable from the Streamlit UI) ──────────
# Use "ollama" for local, "openai"/"anthropic"/"google" for cloud
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.1:8b

# ── LookML Source ──────────────────────────────────────────────
LOOKML_DIR=../looker_fixtures

# ── Retrieval Tuning ──────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.4
AMBIGUITY_THRESHOLD=0.1
TOP_K_FIELDS=15
TOP_K_EXPLORES=5

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
